NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

JWT_SECRET=change-this-secret-in-env
JWT_ISSUER=
JWT_AUDIENCE=

MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID_PREFIX=chat-service

DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chat-app
DB_USER=app_user
DB_PASSWORD=app_password
DB_LOGGING=false
DB_SYNC=true
